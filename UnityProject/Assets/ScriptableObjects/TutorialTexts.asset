--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 2b52afb83e16a0149abc2dcf9935b358, type: 3}
  m_Name: TutorialTexts
  m_EditorClassIdentifier: 
  _infos:
  - _text: "\u30C1\u30E5\u30FC\u30C8\u30EA\u30A2\u30EB\u3078\u3088\u3046\u3053\u305D\uFF01\\n\u30C6\u30AD\u30B9\u30C8\u306F\u5DE6\u30AF\u30EA\u30C3\u30AF\u304B\u30A8\u30F3\u30BF\u30FC\u3067\u9001\u308C\u308B\u3088"
    _condition: 0
  - _text: "\u53F3\u4E0B\u306B\u3042\u308B\u6570\u5B57\u306F\u30BF\u30A4\u30DE\u30FC\u3060\u3088\\n\u3053\u3053\u3092\u30AF\u30EA\u30C3\u30AF\u3059\u308B\u304B\u3001Tab\u30AD\u30FC\u3092\u62BC\u3059\u3068\u30DD\u30FC\u30BA\u753B\u9762\u304C\u51FA\u308B\u304B\u3089\u3001\u305D\u3053\u304B\u3089\u3044\u3064\u3067\u3082\u30C1\u30E5\u30FC\u30C8\u30EA\u30A2\u30EB\u3092\u4E2D\u65AD\u3067\u304D\u308B\u3088"
    _condition: 0
  - _text: "\u3053\u306E\u30B2\u30FC\u30E0\u306E\u6982\u8981\u3092\u8AAC\u660E\u3059\u308B\u3088\\n\u3053\u306E\u30B2\u30FC\u30E0\u306F\u3001"
    _condition: 0
  - _text: "\u300C\u9B54\u6CD5\u306E\u6295\u64F2\u3068\u5408\u4F53\u3092\u99C6\u4F7F\u3057\u3066\u30E2\u30F3\u30B9\u30BF\u30FC\u3092\u5012\u3057\u30011\u79D2\u3067\u3082\u9577\u304F\u751F\u304D\u6B8B\u308C\uFF01\u300D"
    _condition: 0
  - _text: "\u2026\u3063\u3066\u30B2\u30FC\u30E0\u3060\u3088\u3002"
    _condition: 0
  - _text: "\u6B21\u306F\u79FB\u52D5\u3057\u3066\u307F\u3088\u3046"
    _condition: 0
  - _text: "\u30AD\u30FC\u30DC\u30FC\u30C9\u306EA\u304BD\u3001\u307E\u305F\u306F\u77E2\u5370\u30AD\u30FC\u3067\u79FB\u52D5\u3067\u304D\u308B\u3088\\n\u30B8\u30E3\u30F3\u30D7\u306F\u3067\u304D\u306A\u3044\u304B\u3089\u306D"
    _condition: 1
  - _text: "\u30D7\u30EC\u30A4\u30E4\u30FC\u306E\u4E0A\u306B\u3042\u308B\u7DD1\u8272\u306E\u30D0\u30FC\u306FHP\u3092\u3001\u9752\u8272\u306E\u30D0\u30FC\u306F\u9B54\u6CD5\u306E\u30AF\u30FC\u30EB\u30C0\u30A6\u30F3\u3092\u793A\u3057\u3066\u3044\u308B\u3088\\n\u9752\u8272\u306E\u30D0\u30FC\u304C\u6E80\u30BF\u30F3\u306B\u306A\u3063\u3066\u3044\u306A\u3044\u3068\u9B54\u6CD5\u304C\u6253\u3066\u306A\u3044\u3088"
    _condition: 0
  - _text: "\u3068\u3044\u3046\u3053\u3068\u3067\u6B21\u306F\u9B54\u6CD5\u3092\u4F7F\u3063\u3066\u307F\u3088\u3046"
    _condition: 0
  - _text: "\u30DE\u30A6\u30B9\u3092\u5DE6\u30AF\u30EA\u30C3\u30AF\u3057\u3066\u3001\u5DE6\u30AF\u30EA\u30C3\u30AF\u3057\u305F\u307E\u307E\u30D7\u30EC\u30A4\u30E4\u30FC\u306B\u8FD1\u3065\u3051\u3066\u3001\u96E2\u3059\u3068\u9B54\u6CD5\u3092\u6295\u3052\u308C\u308B\u3088"
    _condition: 0
  - _text: "\u9014\u4E2D\u307E\u3067\u306E\u9B54\u6CD5\u306E\u8ECC\u9053\u304C\u8868\u793A\u3055\u308C\u308B\u304B\u3089\u3001\u76EE\u5370\u306B\u3057\u3066\u306D"
    _condition: 0
  - _text: "\u65E9\u901F\u5B9F\u8DF5\uFF01\\n\u524D\u65B9\u306B2\u3064\u306E\u304B\u304B\u3057\u304C\u898B\u3048\u308B\u3088\u306D\\n\u3053\u308C\u306B\u9B54\u6CD5\u3092\u5F53\u3066\u3066\u307F\u3088\u3046"
    _condition: 2
  - _text: "\u30A4\u30BF\u30C3"
    _condition: 0
  - _text: "\u306A\u3093\u3067\u3082\u306A\u3044\u3088\u3002\u304A\u307F\u3054\u3068\uFF01"
    _condition: 0
  - _text: "\u5B9F\u306F\u3001\u9B54\u6CD5\u306F\u6EDE\u7A7A\u6642\u9593\u304C\u9577\u3044\u307B\u3069\u5F53\u305F\u3063\u305F\u3068\u304D\u306B\u3088\u308A\u5927\u304D\u3044\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u3089\u308C\u308B\u3088\\n\u7A4D\u6975\u7684\u306B\u9060\u304F\u304B\u3089\u72D9\u3063\u3066\u307F\u3088\u3046\uFF01"
    _condition: 0
  - _text: "\u9B54\u6CD5\u306E\u7A2E\u985E\u306F\u4E00\u3064\u3060\u3051\u3058\u3083\u306A\u3044\u3088\\n\u6B21\u306F\u9055\u3046\u9B54\u6CD5\u3092\u4F7F\u3063\u3066\u307F\u3088\u3046"
    _condition: 0
  - _text: "\u5DE6\u4E0B\u306E\u30DC\u30BF\u30F3\u304B\u3001Q,E\u30AD\u30FC\u3001\u307E\u305F\u306F\u30DE\u30A6\u30B9\u30DB\u30A4\u30FC\u30EB\u3067\u3082\u9B54\u6CD5\u3092\u5207\u308A\u66FF\u3048\u3089\u308C\u308B\u3088\\n\u3058\u3083\u3042\u3055\u3063\u304D\u3068\u306F\u9055\u3046\u9B54\u6CD5\u3092\u304B\u304B\u3057\u306B\u5F53\u3066\u3066\u307F\u3088\u3046\uFF01"
    _condition: 3
  - _text: "\u30CA\u30A4\u30B9\uFF01"
    _condition: 0
  - _text: "\u30E2\u30F3\u30B9\u30BF\u30FC\u3054\u3068\u306B\u5F31\u70B9\u3068\u306A\u308B\u9B54\u6CD5\u304C\u3042\u308B\u304B\u3089\u63A2\u3057\u3066\u307F\u3066\u306D\uFF01\\n\u5F31\u70B9\u306E\u9B54\u6CD5\u304C\u5F53\u305F\u308B\u3068\u300CCritical\u300D\u3068\u8868\u793A\u3055\u308C\u3066\u3001\u500D\u306E\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u3089\u308C\u308B\u3088\uFF01"
    _condition: 0
  - _text: "\u6700\u5F8C\u306B\u5408\u4F53\u9B54\u6CD5\u306B\u3064\u3044\u3066\u6559\u3048\u308B\u306D"
    _condition: 0
  - _text: "\u7A7A\u4E2D\u3067\u7A2E\u985E\u306E\u7570\u306A\u308B\u9B54\u6CD5\u3092\u885D\u7A81\u3055\u305B\u308B\u3068\u3001\u9B54\u6CD5\u304C\u5408\u4F53\u3057\u3066\u5F37\u529B\u306A\u9B54\u6CD5\u304C\u767A\u52D5\u3059\u308B\u3088"
    _condition: 0
  - _text: "\u885D\u7A81\u3057\u305F\u5143\u306E\u9B54\u6CD5\u306E\u4E0E\u3048\u308B\u30C0\u30E1\u30FC\u30B8\u304C\u5927\u304D\u3044\u307B\u3069\u3001\u5408\u4F53\u9B54\u6CD5\u304C\u4E0E\u3048\u308B\u30C0\u30E1\u30FC\u30B8\u3082\u5927\u304D\u304F\u306A\u308B\u3088"
    _condition: 0
  - _text: "\u5408\u4F53\u9B54\u6CD5\u3092\u767A\u52D5\u3055\u305B\u3066\u307F\u3088\u3046\uFF01\\n\u300C\u7A7A\u4E2D\u3067\u7A2E\u985E\u306E\u7570\u306A\u308B\u9B54\u6CD5\u3092\u885D\u7A81\u3055\u305B\u308B\u300D\u3060\u3088\uFF01"
    _condition: 4
  - _text: "\u30B0\u30EC\u30A4\u30C8\uFF01"
    _condition: 0
  - _text: "\u3053\u308C\u3067\u30C1\u30E5\u30FC\u30C8\u30EA\u30A2\u30EB\u306F\u7D42\u308F\u308A\u3060\u3088\\nThank
      you for playing!"
    _condition: 5
